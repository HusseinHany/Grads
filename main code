string trim(const string& s) {
    int start = 0, end = static_cast<int>(s.size()) - 1;
    while (start <= end && isspace(static_cast<unsigned char>(s[start]))) start++;
    while (end >= start && isspace(static_cast<unsigned char>(s[end]))) end--;
    return (start <= end) ? s.substr(start, end - start + 1) : "";
}

string toLowerCopy(const string& s) {
    string out = s;
    for (char& c : out) c = static_cast<char>(tolower(static_cast<unsigned char>(c)));
    return out;
}

bool containsIgnoreCase(const string& text, const string& query) {
    string t = toLowerCopy(trim(text));
    string q = toLowerCopy(trim(query));
    if (q.empty()) return false;
    return t.find(q) != string::npos;
}

bool equalsIgnoreCase(const string& a, const string& b) {
    return toLowerCopy(trim(a)) == toLowerCopy(trim(b));
}

void validateNameOrThrow(const string& name) {
    string cleaned = trim(name);
    if (cleaned.empty())
        throw invalid_argument("Name cannot be empty.");

    bool hasAlpha = false;
    for (char c : cleaned) {
        if (isalpha(static_cast<unsigned char>(c))) hasAlpha = true;
        else if (!(c == ' ' || c == '-' || c == '\'' || c == '.'))
            throw invalid_argument("Name can contain letters, spaces, '-', '.', and apostrophes only.");
    }

    if (!hasAlpha)
        throw invalid_argument("Name must include letters.");
}

void validateMajorOrThrow(const string& major) {
    string cleaned = trim(major);
    if (cleaned.empty())
        throw invalid_argument("Major cannot be empty.");

    bool hasAlpha = false;
    for (char c : cleaned) {
        if (isalpha(static_cast<unsigned char>(c))) hasAlpha = true;
        else if (!(c == ' ' || c == '-' || c == '&' || c == '/' || c == '.'))
            throw invalid_argument("Major can contain letters, spaces, '-', '&', '/', and '.' only.");
    }

    if (!hasAlpha)
        throw invalid_argument("Major must include letters.");
}

