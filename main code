// --- STATISTICS ---
void statistics() {
    printHeader("STATISTICAL ANALYSIS");

    if (n == 0) { cout << "  No data.\n"; return; }

    double sum = 0, maxG = students[0].gpa, minG = students[0].gpa;

    for (int i = 0; i < n; i++) {
        sum += students[i].gpa;
        if (students[i].gpa > maxG) maxG = students[i].gpa;
        if (students[i].gpa < minG) minG = students[i].gpa;
    }

    double mean = sum / n;
    double variance = 0;
    for (int i = 0; i < n; i++)
        variance += (students[i].gpa - mean) * (students[i].gpa - mean);
    double stdDev = sqrt(variance / n);

    // Median: sort a copy, pick middle
    static Student temp[MAX];
    copyArray(students, temp, n);
    quickSortGPA(temp, 0, n - 1);
    double median = (n % 2 == 0)
        ? (temp[n / 2 - 1].gpa + temp[n / 2].gpa) / 2.0
        : temp[n / 2].gpa;

    cout << "  Total Students : " << n << "\n";
    cout << "  Average GPA    : " << mean << "\n";
    cout << "  Highest GPA    : " << maxG << "\n";
    cout << "  Lowest GPA     : " << minG << "\n";
    cout << "  Median GPA     : " << median << "\n";
    cout << "  Std Deviation  : " << stdDev << "\n";

    // Grade distribution
    int dist[5] = { 0 }; // 0-0.99, 1-1.99, 2-2.99, 3-3.49, 3.5-4.0
    for (int i = 0; i < n; i++) {
        double g = students[i].gpa;
        if (g < 1.0)       dist[0]++;
        else if (g < 2.0)  dist[1]++;
        else if (g < 3.0)  dist[2]++;
        else if (g < 3.5)  dist[3]++;
        else               dist[4]++;
    }

    cout << "\n  GPA Distribution:\n";
    cout << "  < 1.0  (F) : " << dist[0] << " students\n";
    cout << "  1.0-1.99(D): " << dist[1] << " students\n";
    cout << "  2.0-2.99(C): " << dist[2] << " students\n";
    cout << "  3.0-3.49(B): " << dist[3] << " students\n";
    cout << "  3.5-4.0 (A): " << dist[4] << " students\n";
}

