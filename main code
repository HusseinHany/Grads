        // Sort by ID first (required for binary search)
        static Student temp[MAX];
        copyArray(students, temp, n);
        resetCounters();
        insertionSortID(temp, n);

        auto start = high_resolution_clock::now();
        // binary search on temp array
        int left = 0, right = n - 1, found = -1;
        while (left <= right) {
            int mid = left + (right - left) / 2;
            g_comparisons++;
            if (temp[mid].id == id) { found = mid; break; }
            else if (temp[mid].id < id) left = mid + 1;
            else right = mid - 1;
        }
        auto end = high_resolution_clock::now();
        double ms = duration<double, milli>(end - start).count();

        if (found != -1) {
            cout << "\n  [FOUND]\n";
            printStudent(temp[found]);
        }
        else {
            cout << "  [NOT FOUND]\n";
