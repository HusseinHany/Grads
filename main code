// --- DUPLICATE DETECTOR ---
void detectDuplicates() {
    printHeader("DUPLICATE DETECTOR");

    if (n < 2) { cout << "  Need at least 2 records.\n"; return; }

    // Sort a copy by GPA to find duplicate GPAs
    static Student temp[MAX];
    copyArray(students, temp, n);
    quickSortGPA(temp, 0, n - 1);

    bool found = false;
    cout << "  Checking duplicate GPAs (post-sort adjacent scan O(n))...\n\n";
    for (int i = 0; i < n - 1; i++) {
        if (temp[i].gpa == temp[i + 1].gpa) {
            cout << "  Duplicate GPA " << temp[i].gpa << ": "
                << temp[i].name << " & " << temp[i + 1].name << "\n";
            found = true;
        }
    }

    if (!found) cout << "  No duplicate GPAs found.\n";
}

// ============================================================
//  SECTION 5 — AVL TREE (for ID-based fast lookup comparison)
// ============================================================

struct AVLNode {
    Student data;
    AVLNode* left, * right;
    int height;
};

AVLNode* avlRoot = NULL;

int avlHeight(AVLNode* node) {
    return node ? node->height : 0;
}

int avlMax(int a, int b) { return (a > b) ? a : b; }

AVLNode* avlCreate(Student s) {
    AVLNode* node = new AVLNode;
    node->data = s;
    node->left = node->right = NULL;
    node->height = 1;
    return node;
}

AVLNode* avlRightRotate(AVLNode* y) {
    AVLNode* x = y->left;
    AVLNode* T2 = x->right;
    x->right = y;
    y->left = T2;
    y->height = avlMax(avlHeight(y->left), avlHeight(y->right)) + 1;
    x->height = avlMax(avlHeight(x->left), avlHeight(x->right)) + 1;
    return x;
}

AVLNode* avlLeftRotate(AVLNode* x) {
    AVLNode* y = x->right;
    AVLNode* T2 = y->left;
    y->left = x;
    x->right = T2;
    x->height = avlMax(avlHeight(x->left), avlHeight(x->right)) + 1;
    y->height = avlMax(avlHeight(y->left), avlHeight(y->right)) + 1;
    return y;
}

int avlGetBalance(AVLNode* node) {
    return node ? avlHeight(node->left) - avlHeight(node->right) : 0;
}

AVLNode* avlInsert(AVLNode* node, Student s) {
    if (!node) return avlCreate(s);
    if (s.id < node->data.id)       node->left = avlInsert(node->left, s);
    else if (s.id > node->data.id)  node->right = avlInsert(node->right, s);
    else return node;

    node->height = 1 + avlMax(avlHeight(node->left), avlHeight(node->right));
    int balance = avlGetBalance(node);

    if (balance > 1 && s.id < node->left->data.id)  return avlRightRotate(node);
    if (balance < -1 && s.id > node->right->data.id) return avlLeftRotate(node);
    if (balance > 1 && s.id > node->left->data.id) { node->left = avlLeftRotate(node->left);  return avlRightRotate(node); }
    if (balance < -1 && s.id < node->right->data.id) { node->right = avlRightRotate(node->right); return avlLeftRotate(node); }

    return node;
}

AVLNode* avlSearch(AVLNode* node, int id) {
    if (!node) return NULL;
    g_comparisons++;
    if (id == node->data.id) return node;
    if (id < node->data.id)  return avlSearch(node->left, id);
    return avlSearch(node->right, id);
}

void avlInorder(AVLNode* node) {
    if (node) {
        avlInorder(node->left);
        printStudent(node->data);
        avlInorder(node->right);
    }
}

