// --- LINEAR SEARCH (by Name) ---
// O(n) — no precondition required

int linearSearchName(const string& name) {
    for (int i = 0; i < n; i++) {
        g_comparisons++;
        if (equalsIgnoreCase(students[i].name, name)) return i;
    }
    return -1;
}

// --- BINARY SEARCH (by ID) ---
// O(log n) — array MUST be sorted by ID first

int binarySearchID(int id) {
    int left = 0, right = n - 1;
    while (left <= right) {
        int mid = left + (right - left) / 2;
        g_comparisons++;
        if (students[mid].id == id) return mid;
        else if (students[mid].id < id) left = mid + 1;
        else right = mid - 1;
    }
    return -1;
}

