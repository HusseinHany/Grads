//  SECTION 2 — SORTING ALGORITHMS (ALL MANUAL, NO STD SORT)
// ============================================================

// --- 1. BUBBLE SORT (by GPA, descending) ---
// Best: O(n)  |  Average: O(n²)  |  Worst: O(n²)
// Scenario: Re-sort after adding one student to a nearly-sorted list.

void bubbleSortGPA(Student arr[], int size) {
    for (int i = 0; i < size - 1; i++) {
        bool swapped = false;
        for (int j = 0; j < size - i - 1; j++) {
            g_comparisons++;
            if (arr[j].gpa < arr[j + 1].gpa) {
                swapStudents(arr[j], arr[j + 1]);
                swapped = true;
            }
        }
        if (!swapped) break;   // early exit — best case O(n)
    }
}

// --- 2. INSERTION SORT (by ID, ascending) ---
// Best: O(n)  |  Average: O(n²)  |  Worst: O(n²)
// Scenario: Small class roster built incrementally.

void insertionSortID(Student arr[], int size) {
    for (int i = 1; i < size; i++) {
        Student key = arr[i];
        int j = i - 1;
        while (j >= 0 && arr[j].id > key.id) {
            g_comparisons++;
            arr[j + 1] = arr[j];
            g_swaps++;
            j--;
        }
        g_comparisons++;
        arr[j + 1] = key;
    }
}

// --- 3. SELECTION SORT (by Age, ascending) ---
// Best: O(n²)  |  Average: O(n²)  |  Worst: O(n²)
// Scenario: When minimizing write (swap) operations matters.

void selectionSortAge(Student arr[], int size) {
    for (int i = 0; i < size - 1; i++) {
        int minIdx = i;
        for (int j = i + 1; j < size; j++) {
            g_comparisons++;
            if (arr[j].age < arr[minIdx].age)
                minIdx = j;
        }
        if (minIdx != i)
            swapStudents(arr[i], arr[minIdx]);
    }
}

// --- 4. MERGE SORT (by Name, alphabetical) ---
// Best: O(n log n)  |  Average: O(n log n)  |  Worst: O(n log n)
// Scenario: Large export requiring guaranteed O(n log n), stable sort.

void mergeByName(Student arr[], int left, int mid, int right) {
    int n1 = mid - left + 1;
    int n2 = right - mid;

    Student* L = new Student[n1];
    Student* R = new Student[n2];

    for (int i = 0; i < n1; i++) L[i] = arr[left + i];
    for (int j = 0; j < n2; j++) R[j] = arr[mid + 1 + j];

    int i = 0, j = 0, k = left;

    while (i < n1 && j < n2) {
        g_comparisons++;
        if (L[i].name <= R[j].name)
            arr[k++] = L[i++];
        else
            arr[k++] = R[j++];
    }

    while (i < n1) arr[k++] = L[i++];
    while (j < n2) arr[k++] = R[j++];

    delete[] L;
    delete[] R;
}

void mergeSortName(Student arr[], int left, int right) {
    if (left < right) {
        int mid = left + (right - left) / 2;
        mergeSortName(arr, left, mid);
        mergeSortName(arr, mid + 1, right);
        mergeByName(arr, left, mid, right);
    }
}

// --- 5. QUICK SORT (by GPA, descending) ---
// Best: O(n log n)  |  Average: O(n log n)  |  Worst: O(n²)
// Scenario: Large directory sort, average-case fastest.
// Uses median-of-three pivot to reduce worst-case probability.

int medianOfThree(Student arr[], int low, int high) {
    int mid = low + (high - low) / 2;
    if (arr[low].gpa < arr[mid].gpa)   swapStudents(arr[low], arr[mid]);
    if (arr[low].gpa < arr[high].gpa)  swapStudents(arr[low], arr[high]);
    if (arr[mid].gpa < arr[high].gpa)  swapStudents(arr[mid], arr[high]);
    swapStudents(arr[mid], arr[high - 1]);
    return high - 1;
}

int partitionGPA(Student arr[], int low, int high) {
    double pivot;
    if (high - low < 3) {
        pivot = arr[high].gpa;
    }
    else {
        int pivotIdx = medianOfThree(arr, low, high);
        pivot = arr[pivotIdx].gpa;
    }

    int i = low - 1;
    for (int j = low; j < high; j++) {
        g_comparisons++;
        if (arr[j].gpa > pivot) {
            i++;
            swapStudents(arr[i], arr[j]);
        }
    }
    swapStudents(arr[i + 1], arr[high]);
    return i + 1;
}

void quickSortGPA(Student arr[], int low, int high) {
    if (low < high) {
        int pi = partitionGPA(arr, low, high);
        quickSortGPA(arr, low, pi - 1);
        quickSortGPA(arr, pi + 1, high);
    }
}

