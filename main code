void addStudent() {
    printHeader("ADD STUDENT");

    if (n >= MAX) {
        cout << "\033[31m  [ERROR] Storage full!\033[0m\n";
        return;
    }

    Student s;

    // 1. Validate ID (Must be positive integer and unique)
    while (true) {
        cout << "  Enter ID : ";
        if (cin >> s.id && s.id > 0) {
            if (idExists(s.id)) {
                cout << "\033[31m  [ERROR] ID already exists. Try again.\033[0m\n";
            }
            else {
                break; // Valid and unique
            }
        }
        else {
            cout << "\033[31m  [ERROR] Invalid ID. Please enter a positive number.\033[0m\n";
            cin.clear();
            cin.ignore(1000, '\n');
        }
    }

    cin.ignore(); // Clear buffer before getline

    // 2. Validate Name (exception-safe validation)
    while (true) {
        cout << "Enter Name : ";
        getline(cin, s.name);
        try {
            validateNameOrThrow(s.name);
            s.name = trim(s.name);
            break;
        }
        catch (const exception& e) {
            cout << "\033[31m  [ERROR] " << e.what() << "\033[0m\n";
        }
    }

    // 3. Validate GPA (Already handled, but added type-safety)
    while (true) {
        cout << "Enter GPA : ";
        if (cin >> s.gpa && s.gpa >= 0.0 && s.gpa <= 4.0) {
            break;
        }
        else {
            cout << "\033[31m  [ERROR] Invalid GPA (0.0 - 4.0). Re-enter: \033[0m";
            cin.clear();
            cin.ignore(1000, '\n');
        }
    }

    // 4. Validate Age (Reasonable range)
    while (true) {
        cout << "Enter Age : ";
        if (cin >> s.age && s.age >= 16 && s.age <= 100) {
            break;
        }
        else {
            cout << "\033[31m  [ERROR] Invalid Age (16 - 100). Re-enter: \033[0m";
            cin.clear();
            cin.ignore(1000, '\n');
        }
    }

    cin.ignore();

    // 5. Validate Major
    while (true) {
        cout << "Enter Major : ";
        getline(cin, s.major);
        try {
            validateMajorOrThrow(s.major);
            s.major = trim(s.major);
            break;
        }
        catch (const exception& e) {
            cout << "\033[31m  [ERROR] " << e.what() << "\033[0m\n";
        }
    }

    students[n++] = s;
    cout << "\033[32m\n  [SUCCESS] Student " << s.name << " added successfully!\033[0m\n";
}

