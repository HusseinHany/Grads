void generateRandom(Student arr[], int size) {
    srand(time(0));
    string names[] = { "Ali","Sara","Omar","Lina","Hassan","Nour","Yusuf","Dina","Khaled","Maya" };
    string majors[] = { "CS","EE","ME","CE","IT","Math","Physics","Bio","Chem","Arch" };

    for (int i = 0; i < size; i++) {
        arr[i].id = i + 1;
        arr[i].name = names[rand() % 10] + " " + to_string(i);
        arr[i].gpa = (rand() % 401) / 100.0;
        arr[i].age = 18 + rand() % 10;
        arr[i].major = majors[rand() % 10];
    }
}

void generateNearlySorted(Student arr[], int size) {
    generateRandom(arr, size);
    quickSortGPA(arr, 0, size - 1);
    int disturb = size / 20;
    for (int i = 0; i < disturb; i++) {
        int a = rand() % size, b = rand() % size;
        swapStudents(arr[a], arr[b]);
    }
}

void generateReverseSorted(Student arr[], int size) {
    generateRandom(arr, size);
    quickSortGPA(arr, 0, size - 1);
    // reverse
    for (int i = 0, j = size - 1; i < j; i++, j--)
        swapStudents(arr[i], arr[j]);
}

struct BenchResult {
    string algorithm;
    int    dataSize;
    string dataType;
    double timeMs;
    long long comparisons;
    long long swaps;
};

BenchResult results[200];
int resultCount = 0;

void runBenchmark() {
    printHeader("BENCHMARKING ENGINE");
    cout << "  This will benchmark ALL 5 sorting algorithms\n";
    cout << "  across 3 data types x 4 dataset sizes.\n";
    cout << "  Total runs: 60\n\n";
    cout << "  Press ENTER to start...\n";
    cin.clear();
    if (cin.rdbuf()->in_avail() > 0) {
        cin.ignore(numeric_limits<streamsize>::max(), '\n');
    }
    cin.get();

    int sizes[] = { 50, 1000, 10000, 100000 };
    int numSizes = 4;

    string dataTypes[] = { "Random", "Nearly Sorted", "Reverse Sorted" };

    resultCount = 0;

    for (int di = 0; di < 3; di++) {
        for (int si = 0; si < numSizes; si++) {
            int sz = sizes[si];
            Student* base = new Student[sz];

            if (di == 0)      generateRandom(base, sz);
            else if (di == 1) generateNearlySorted(base, sz);
            else              generateReverseSorted(base, sz);

            Student* arr = new Student[sz];

            // Test each algorithm
            string algNames[] = { "Bubble Sort","Insertion Sort","Selection Sort","Merge Sort","Quick Sort" };

            for (int ai = 0; ai < 5; ai++) {
                // Skip O(n²) on large datasets if they'd time out
                // (still run them for completeness up to 10000)
                bool skipHeavy = (sz == 100000 && ai < 3);

                copyArray(base, arr, sz);
                resetCounters();

                auto start = high_resolution_clock::now();

                if (!skipHeavy) {
                    if (ai == 0) bubbleSortGPA(arr, sz);
                    else if (ai == 1) insertionSortID(arr, sz);
                    else if (ai == 2) selectionSortAge(arr, sz);
                    else if (ai == 3) mergeSortName(arr, 0, sz - 1);
                    else              quickSortGPA(arr, 0, sz - 1);
                }

                auto end = high_resolution_clock::now();
                double ms = skipHeavy ? -1.0
                    : duration<double, milli>(end - start).count();

                BenchResult& r = results[resultCount++];
                r.algorithm = algNames[ai];
                r.dataSize = sz;
                r.dataType = dataTypes[di];
                r.timeMs = ms;
                r.comparisons = skipHeavy ? -1 : g_comparisons;
                r.swaps = skipHeavy ? -1 : g_swaps;
            }

            delete[] base;
            delete[] arr;
        }
    }

    // Print results table
    cout << "\n\n";
    cout << "==================================\n";
    cout << "  BENCHMARK RESULTS\n";
    cout << "==================================\n";
    cout << "  Algorithm        | Size    | Data Type     | Time(ms)    | Comparisons  | Swaps\n";
    cout << "  -----------------+---------+---------------+-------------+--------------+----------\n";

    for (int i = 0; i < resultCount; i++) {
        BenchResult& r = results[i];
        cout << "  ";
        cout.width(17); cout << left << r.algorithm;
        cout << "| ";
        cout.width(8);  cout << left << r.dataSize;
        cout << "| ";
        cout.width(15); cout << left << r.dataType;
        cout << "| ";
        if (r.timeMs < 0)
            cout.width(12), cout << left << "SKIPPED";
        else
            cout.width(12), cout << left << r.timeMs;
        cout << "| ";
        if (r.comparisons < 0)
            cout.width(13), cout << left << "SKIPPED";
        else
            cout.width(13), cout << left << r.comparisons;
        cout << "| ";
        if (r.swaps < 0)
            cout << "SKIPPED";
        else
            cout << r.swaps;
        cout << "\n";
    }

    cout << "==================================\n";
    cout << "  Note: O(n2) algorithms skipped at n=100,000 (impractical).\n";
}

