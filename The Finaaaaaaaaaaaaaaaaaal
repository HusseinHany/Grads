void printRow(const Student& s, int rowNum = -1) {
    string gc = gpaCol(s.gpa);
    string row = (rowNum >= 0) ? to_string(rowNum) : " ";
    cout << "  | " << pad(row, 1) << " | "
        << pad(to_string(s.id), 8) << " | "
        << pad(s.name, 19) << " | "
        << gc << pad(dbl(s.gpa), 4) << "\033[0m" << " | "
        << gc << pad(letterGrade(s.gpa), 2) << "\033[0m" << " | "
        << pad(to_string(s.age), 3) << " | "
        << pad(s.major, 18) << " |\n";
}

