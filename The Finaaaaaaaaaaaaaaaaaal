struct BenchResult { string alg, dt; int sz; double ms; long long cmp, sw; };
BenchResult benchResults[300];
int benchCount = 0;

void runBenchmark() {
    header("BENCHMARKING ENGINE", "5 algorithms x 4 sizes x 3 distributions = 60 runs");
    cout << "  Sizes : 50 | 1,000 | 10,000 | 100,000\n";
    cout << "  Types : Random | Nearly Sorted | Reverse Sorted\n\n";
    msgWRN("O(n^2) algorithms skipped at n=100,000 (~90s each).");
    cout << "\n  Press Enter to start..."; cin.get();

    const int sz[] = { 50,1000,10000,100000 };
    const string dt[] = { "Random","Nearly Sorted","Reverse Sorted" };
    const string alg[] = { "Bubble Sort","Insertion Sort","Selection Sort","Merge Sort","Quick Sort" };
    const string ac[] = { "\033[31m","\033[33m","\033[33m","\033[32m","\033[32m" };

    benchCount = 0;
    srand((unsigned)time(0));

    for (int di = 0; di < 3; di++) {
        cout << "\n\033[36m\033[1m  --- " << dt[di] << " ---\033[0m\n\n";
        for (int si = 0; si < 4; si++) {
            int s = sz[si];
            Student* base = new Student[s]; Student* arr = new Student[s];
            if (di == 0) generateRandom(base, s);
            else if (di == 1) generateNearlySorted(base, s);
            else generateReverseSorted(base, s);

            for (int ai = 0; ai < 5; ai++) {
                bool skip = (s == 100000 && ai < 3);
                copyArray(base, arr, s); resetCounters();
                double ms = -1;
                if (!skip) {
                    auto t0 = high_resolution_clock::now();
                    if (ai == 0) bubbleSortGPA(arr, s);
                    else if (ai == 1) insertionSortID(arr, s);
                    else if (ai == 2) selectionSortAge(arr, s);
                    else if (ai == 3) mergeSortName(arr, 0, s - 1);
                    else quickSortGPA(arr, 0, s - 1);
                    ms = duration<double, milli>(high_resolution_clock::now() - t0).count();
                }
                BenchResult& r = benchResults[benchCount++];
                r.alg = alg[ai]; r.sz = s; r.dt = dt[di]; r.ms = ms;
                r.cmp = skip ? -1 : g_comparisons; r.sw = skip ? -1 : g_swaps;

                cout << "  " << ac[ai] << pad(alg[ai], 16) << "\033[0m"
                    << " n=" << setw(7) << left << s;
                if (skip) cout << "\033[33m  SKIPPED\033[0m\n";
                else     cout << "\033[32m  " << setw(10) << left << dbl(ms, 3) << "ms"
                    << "   cmp=" << r.cmp << "\033[0m\n";
            }
            delete[] base; delete[] arr;
        }
    }

    cout << "\n\n"; divider('=', 86);
    cout << "\033[1m  FULL RESULTS TABLE\033[0m\n"; divider('=', 86);
    cout << "\033[36m"
        << "  Algorithm        | Size     | Type           | Time(ms)    | Comparisons   | Swaps\n"
        << "  -----------------+----------+----------------+-------------+---------------+-----------\n"
        << "\033[0m";
    for (int i = 0; i < benchCount; i++) {
        BenchResult& r = benchResults[i];
        cout << "  " << pad(r.alg, 17) << "| " << pad(to_string(r.sz), 9)
            << "| " << pad(r.dt, 15) << "| "
            << pad(r.ms < 0 ? "SKIPPED" : dbl(r.ms, 3), 12) << "| "
            << pad(r.cmp < 0 ? "SKIPPED" : to_string(r.cmp), 14) << "| "
            << (r.sw < 0 ? "SKIPPED" : to_string(r.sw)) << "\n";
    }
    divider('=', 86);

    sectionTitle("VISUAL COMPARISON  (n=10,000, Random data)");
    double mxMs = 0;
    for (int i = 0; i < benchCount; i++)
        if (benchResults[i].sz == 10000 && benchResults[i].dt == "Random" && benchResults[i].ms > mxMs)
            mxMs = benchResults[i].ms;
    int ai2 = 0;
    for (int i = 0; i < benchCount; i++) {
        BenchResult& r = benchResults[i];
        if (r.sz == 10000 && r.dt == "Random") {
            cout << "  " << ac[ai2] << pad(r.alg, 16) << "\033[0m [";
            if (r.ms < 0) { cout << "         SKIPPED          "; }
            else {
                int filled = (mxMs > 0) ? (int)(r.ms * 26 / mxMs) : 0;
                cout << ac[ai2];
                for (int b = 0; b < filled; b++) cout << "#";
                cout << "\033[0m";
                for (int b = filled; b < 26; b++) cout << ".";
            }
            cout << "] ";
            if (r.ms < 0) cout << "SKIPPED\n";
            else       cout << dbl(r.ms, 3) << " ms\n";
            ai2++;
        }
    }
}

