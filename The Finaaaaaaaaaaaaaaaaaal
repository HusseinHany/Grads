void swapStudents(Student& a, Student& b) {
    Student t = a; a = b; b = t;
    g_swaps++;
}

void copyArray(Student src[], Student dst[], int sz) {
    for (int i = 0; i < sz; i++) dst[i] = src[i];
}

void resetCounters() { g_comparisons = 0; g_swaps = 0; }

string dbl(double v, int dec = 2) {
    ostringstream ss;
    ss << fixed << setprecision(dec) << v;
    return ss.str();
}

string pad(const string& s, int w) {
    if ((int)s.size() >= w) return s.substr(0, w - 1) + ">";
    return s + string(w - s.size(), ' ');
}

string letterGrade(double gpa) {
    if (gpa >= 3.7) return "A+";
    if (gpa >= 3.3) return "A ";
    if (gpa >= 3.0) return "B+";
    if (gpa >= 2.7) return "B ";
    if (gpa >= 2.3) return "C+";
    if (gpa >= 2.0) return "C ";
    if (gpa >= 1.5) return "D ";
    return "F ";
}

string gpaCol(double gpa) {
    if (gpa >= 3.5) return "\033[32m";
    if (gpa >= 2.0) return "\033[33m";
    return "\033[31m";
}

