        }
        else if (a == 'A') { addStudent(); pause(); }
        else if (a == 'F') { filterByMajor(); pause(); }
        else if (a == 'D') {
            if (n < 2) { msgERR("Need 2+ records."); pause(); continue; }
            Student* t2 = new Student[n]; copyArray(students, t2, n);
            quickSortGPA(t2, 0, n - 1);
            bool found = false; int cnt = 0;
            for (int i = 0; i < n - 1; i++) {
                if (t2[i].gpa == t2[i + 1].gpa) {
                    cout << "\033[33m  [DUP #" << ++cnt << "] GPA " << dbl(t2[i].gpa)
                        << "  ->  " << t2[i].name << "  &  " << t2[i + 1].name << "\033[0m\n";
                    found = true;
                }
            }
            if (!found) msgOK("No duplicates.");
            delete[] t2; pause();
        }
        else if (a == 'E') {
            string fname = "students_export.csv";
            ofstream f(fname);
            if (!f.is_open()) { msgERR("Cannot open file."); pause(); continue; }
            f << "ID,Name,GPA,Grade,Age,Major\n";
            for (int i = 0; i < n; i++)
                f << students[i].id << "," << "\"" << students[i].name << "\","
                << fixed << setprecision(2) << students[i].gpa << ","
                << letterGrade(students[i].gpa) << ","
                << students[i].age << "," << "\"" << students[i].major << "\"\n";
            f.close();
            msgOK("Exported " + to_string(n) + " records to " + fname);
            pause();
        }
        else { msgERR("Invalid action."); pause(); }
    }
}

