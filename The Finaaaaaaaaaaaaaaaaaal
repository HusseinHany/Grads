bool idExists(int id) {
    for (int i = 0; i < n; i++)
        if (students[i].id == id) return true;
    return false;
}

bool validName(const string& s) {
    bool has = false;
    for (char c : s) {
        if (!isalpha((unsigned char)c) && c != ' ') return false;
        if (isalpha((unsigned char)c)) has = true;
    }
    return has;
}

int readInt(const string& prompt, int lo, int hi) {
    int v;
    while (true) {
        cout << "  " << prompt;
        if (cin >> v && v >= lo && v <= hi) { cin.ignore(1000, '\n'); return v; }
        msgERR("Enter a number between " + to_string(lo) + " and " + to_string(hi) + ".");
        cin.clear(); cin.ignore(1000, '\n');
    }
}

double readDouble(const string& prompt, double lo, double hi) {
    double v;
    while (true) {
        cout << "  " << prompt;
        if (cin >> v && v >= lo && v <= hi) { cin.ignore(1000, '\n'); return v; }
        msgERR("Enter a value between " + dbl(lo) + " and " + dbl(hi) + ".");
        cin.clear(); cin.ignore(1000, '\n');
    }
}

string readName(const string& prompt) {
    string s;
    while (true) {
        cout << "  " << prompt;
        getline(cin, s);
        if (validName(s)) return s;
        msgERR("Letters and spaces only. No digits or symbols.");
    }
}

string chooseMajor() {
    cout << "\n";
    divider('-', 36);
    cout << "  SELECT MAJOR\n";
    divider('-', 36);
    for (int i = 0; i < NUM_MAJORS; i++)
        cout << "  \033[33m" << setw(2) << right << (i + 1) << "\033[0m. " << MAJORS[i] << "\n";
    divider('-', 36);
    return MAJORS[readInt("Choice (1-10): ", 1, NUM_MAJORS) - 1];
}

void saveToFile() {
    ofstream f(DATA_FILE);
    if (!f.is_open()) { msgERR("Cannot write to " + DATA_FILE); return; }
    f << n << "\n";
    for (int i = 0; i < n; i++) {
        f << students[i].id << "\n"
            << students[i].name << "\n"
            << fixed << setprecision(2) << students[i].gpa << "\n"
            << students[i].age << "\n"
            << students[i].major << "\n";
    }
    f.close();
}

void loadFromFile() {
    ifstream f(DATA_FILE);
    if (!f.is_open()) return;
    int count = 0;
    f >> count;
    f.ignore(1000, '\n');
    int loaded = 0;
    for (int i = 0; i < count && loaded < MAX; i++) {
        Student s;
        string idStr;
        getline(f, idStr);
        if (idStr.empty()) getline(f, idStr);
        s.id = atoi(idStr.c_str());
        getline(f, s.name);
        string gpaStr; getline(f, gpaStr);
        s.gpa = atof(gpaStr.c_str());
        string ageStr; getline(f, ageStr);
        s.age = atoi(ageStr.c_str());
        getline(f, s.major);
        if (s.id > 0 && !s.name.empty()) {
            students[loaded++] = s;
        }
    }
    n = loaded;
    f.close();
}

void paginatedDisplay(Student arr[], int total, const string& title) {
    if (total == 0) { msgERR("No records to display."); return; }
    int page = 0;
    int pages = (total + PAGE_SIZE - 1) / PAGE_SIZE;

    while (true) {
        clrscr();
        header(title, to_string(total) + " records total");

        int start = page * PAGE_SIZE;
        int end = min(start + PAGE_SIZE, total);
        tableHeader();
        for (int i = start; i < end; i++) printRow(arr[i], i + 1);
        tableFooter();

        cout << "\n\033[2m  Page " << (page + 1) << " / " << pages
            << "   Rows " << (start + 1) << "-" << end
            << " of " << total << "\033[0m\n";

        cout << "\n  ";
        if (page > 0)         cout << "\033[33mP\033[0m  Prev    ";
        if (page < pages - 1) cout << "\033[33mN\033[0m  Next    ";
        cout << "\033[33mX\033[0m  Back\n";
        cout << "  Action: ";

        string a; cin >> a; cin.ignore(1000, '\n');
        char c = (char)toupper((unsigned char)a[0]);
        if (c == 'X')                   break;
        else if (c == 'N' && page < pages - 1) page++;
        else if (c == 'P' && page > 0)       page--;
    }
}

void addStudent() {
    header("ADD STUDENT");
    if (n >= MAX) { msgERR("Storage full."); return; }

    Student s;
    while (true) {
        cout << "  ID   : ";
        if (cin >> s.id && s.id > 0) {
            cin.ignore(1000, '\n');
            if (!idExists(s.id)) break;
            msgERR("ID " + to_string(s.id) + " already exists.");
        }
        else {
            msgERR("ID must be a positive integer.");
            cin.clear(); cin.ignore(1000, '\n');
        }
    }

    s.name = readName("Name : ");
    s.gpa = readDouble("GPA  (0.00 - 4.00) : ", 0.0, 4.0);
    s.age = readInt("Age  (16 - 100)    : ", 16, 100);
    s.major = chooseMajor();
    students[n++] = s;

    saveToFile();

    cout << "\n";
    tableHeader(); printRow(s, n); tableFooter();
    msgOK("Added: " + s.name + "  GPA: " + dbl(s.gpa) + " (" + letterGrade(s.gpa) + ")");
    msgINF("Saved to " + DATA_FILE);
}

void deleteStudent() {
    header("DELETE STUDENT");
    int id;
    cout << "  Enter ID: ";
    while (!(cin >> id)) { msgERR("Invalid."); cin.clear(); cin.ignore(1000, '\n'); cout << "  Enter ID: "; }
    cin.ignore(1000, '\n');

    for (int i = 0; i < n; i++) {
        if (students[i].id == id) {
            cout << "\n  About to delete:\n";
            tableHeader(); printRow(students[i], i + 1); tableFooter();
            cout << "\n  Confirm? (Y/N): ";
            string c; cin >> c; cin.ignore(1000, '\n');
            if (toupper((unsigned char)c[0]) != 'Y') { msgINF("Cancelled."); return; }
            for (int j = i; j < n - 1; j++) students[j] = students[j + 1];
            n--;
            saveToFile();
            msgOK("Deleted."); msgINF("Saved to " + DATA_FILE);
            return;
        }
    }
    msgERR("ID " + to_string(id) + " not found.");
}

