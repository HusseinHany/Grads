    if (n < 2) { msgERR("Need at least 2 records."); return; }
    Student* tmp = new Student[n]; copyArray(students, tmp, n);
    quickSortGPA(tmp, 0, n - 1);
    msgINF("Method: sort copy -> adjacent scan   O(n log n) + O(n)");
    cout << "\n";
    bool found = false; int cnt = 0;
    for (int i = 0; i < n - 1; i++) {
        if (tmp[i].gpa == tmp[i + 1].gpa) {
            cout << "\033[33m  [DUP #" << ++cnt << "] GPA " << dbl(tmp[i].gpa)
                << "  ->  " << tmp[i].name << "  &  " << tmp[i + 1].name << "\033[0m\n";
