void header(const string& t, const string& sub = "") {
    cout << "\n\033[1m\033[36m";
    divider('=', 60);
    cout << "  " << t << "\n";
    if (!sub.empty()) cout << "\033[0m\033[2m  " << sub << "\n\033[1m\033[36m";
    divider('=', 60);
    cout << "\033[0m\n";
}

void msgOK(const string& m) { cout << "\n\033[32m  [OK]  " << m << "\033[0m\n"; }
void msgERR(const string& m) { cout << "\033[31m  [!]   " << m << "\033[0m\n"; }
void msgINF(const string& m) { cout << "\033[36m  [i]   " << m << "\033[0m\n"; }
void msgWRN(const string& m) { cout << "\033[33m  [~]   " << m << "\033[0m\n"; }

void boxTop(int w = 54) { cout << "  +"; for (int i = 0; i < w; i++) cout << "-"; cout << "+ \n"; }
void boxBot(int w = 54) { boxTop(w); }
void boxRow(const string& lbl, const string& val, const string& col = "", int w = 54) {
    string line = "  " + lbl + val;
    while ((int)line.size() < w) line += " ";
    cout << "  |" << col << line << "\033[0m|\n";
}

void barChart(const string& lbl, int val, int mx, int barW, const string& col) {
    int filled = (mx > 0) ? val * barW / mx : 0;
    int pct = (mx > 0) ? val * 100 / mx : 0;
    cout << "  " << pad(lbl, 16) << " [";
    cout << col;
    for (int i = 0; i < filled; i++) cout << "#";
    cout << "\033[0m";
    for (int i = filled; i < barW; i++) cout << ".";
    cout << "] " << setw(4) << right << val
        << "  (" << setw(3) << right << pct << "%)\n";
}

