// ============================================================
//  SECTION 5 — AVL TREE
// ============================================================

struct AVLNode {
    Student  data;
    AVLNode* left;
    AVLNode* right;
    int      height;
};

AVLNode* avlRoot = NULL;

int  avlH(AVLNode* nd) { return nd ? nd->height : 0; }
int  avlMax(int a, int b) { return a > b ? a : b; }
int  avlBal(AVLNode* nd) { return nd ? avlH(nd->left) - avlH(nd->right) : 0; }

AVLNode* avlNew(Student s) {
    AVLNode* nd = new AVLNode;
    nd->data = s;
    nd->left = nd->right = NULL;
    nd->height = 1;
    return nd;
}

AVLNode* avlRR(AVLNode* y) {
    AVLNode* x = y->left, * T2 = x->right;
    x->right = y; y->left = T2;
    y->height = avlMax(avlH(y->left), avlH(y->right)) + 1;
    x->height = avlMax(avlH(x->left), avlH(x->right)) + 1;
    return x;
}
AVLNode* avlLR(AVLNode* x) {
    AVLNode* y = x->right, * T2 = y->left;
    y->left = x; x->right = T2;
    x->height = avlMax(avlH(x->left), avlH(x->right)) + 1;
    y->height = avlMax(avlH(y->left), avlH(y->right)) + 1;
    return y;
}

AVLNode* avlInsert(AVLNode* nd, Student s) {
    if (!nd) return avlNew(s);
    if (s.id < nd->data.id) nd->left = avlInsert(nd->left, s);
    else if (s.id > nd->data.id) nd->right = avlInsert(nd->right, s);
    else return nd;

    nd->height = 1 + avlMax(avlH(nd->left), avlH(nd->right));
    int b = avlBal(nd);

    if (b > 1 && s.id < nd->left->data.id)                              return avlRR(nd);
    if (b < -1 && s.id > nd->right->data.id)                             return avlLR(nd);
    if (b > 1 && s.id > nd->left->data.id) { nd->left = avlLR(nd->left);  return avlRR(nd); }
    if (b < -1 && s.id < nd->right->data.id) { nd->right = avlRR(nd->right); return avlLR(nd); }
    return nd;
}

AVLNode* avlSearch(AVLNode* nd, int id) {
    if (!nd) return NULL;
    g_comparisons++;
    if (id == nd->data.id) return nd;
    if (id < nd->data.id) return avlSearch(nd->left, id);
    return                        avlSearch(nd->right, id);
}

void avlInorder(AVLNode* nd) {
    if (nd) { avlInorder(nd->left); printStudent(nd->data); avlInorder(nd->right); }
}

