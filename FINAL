void generateRandom(Student arr[], int size) {
    srand((unsigned)time(0));
    const string names[] = { "Ali","Sara","Omar","Lina","Hassan","Nour","Yusuf","Dina","Khaled","Maya" };
    const int    nNames = 10;

    for (int i = 0; i < size; i++) {
        arr[i].id = i + 1;
        arr[i].name = names[rand() % nNames] + " " + to_string(i + 1);
        arr[i].gpa = (rand() % 401) / 100.0;
        arr[i].age = 18 + rand() % 10;
        arr[i].major = MAJORS[rand() % NUM_MAJORS];
    }
}

void generateNearlySorted(Student arr[], int size) {
    generateRandom(arr, size);
    quickSortGPA(arr, 0, size - 1);
    int disturb = size / 20;            
    for (int i = 0; i < disturb; i++) {
        int a = rand() % size, b = rand() % size;
        swapStudents(arr[a], arr[b]);
    }
}

void generateReverseSorted(Student arr[], int size) {
    generateRandom(arr, size);
    quickSortGPA(arr, 0, size - 1);
    for (int i = 0, j = size - 1; i < j; i++, j--)
        swapStudents(arr[i], arr[j]);
}

// ============================================================
//  SECTION 7 — BENCHMARKING ENGINE
// ============================================================

struct BenchResult {
    string    algorithm;
    int       dataSize;
    string    dataType;
    double    timeMs;
    long long comparisons;
    long long swaps;
};

BenchResult benchResults[300];
int         benchCount = 0;

void runBenchmark() {
    printHeader("BENCHMARKING ENGINE");

    cout << "  Benchmarks ALL 5 algorithms across:\n";
    cout << "  • 4 dataset sizes : 50 | 1,000 | 10,000 | 100,000\n";
    cout << "  • 3 distributions : Random | Nearly Sorted | Reverse Sorted\n";
    cout << "  Total test runs   : 60\n\n";
    cout << "  \033[33mNote:\033[0m O(n²) algorithms are skipped at n=100,000\n";
    cout << "        (would take ~90 seconds each).\n\n";
    cout << "  Press Enter to start...";
    cin.get();

    const int    sizes[] = { 50, 1000, 10000, 100000 };
    const int    numSizes = 4;
    const string dataTypes[] = { "Random", "Nearly Sorted", "Reverse Sorted" };
    const string algNames[] = { "Bubble Sort","Insertion Sort","Selection Sort","Merge Sort","Quick Sort" };

    benchCount = 0;

    for (int di = 0; di < 3; di++) {
        cout << "\n  \033[36mRunning: " << dataTypes[di] << " data...\033[0m\n";

        for (int si = 0; si < numSizes; si++) {
            int sz = sizes[si];

            Student* base = new Student[sz];
            Student* arr = new Student[sz];

            if (di == 0) generateRandom(base, sz);
            else if (di == 1) generateNearlySorted(base, sz);
            else              generateReverseSorted(base, sz);

            for (int ai = 0; ai < 5; ai++) {
                bool skip = (sz == 100000 && ai < 3);

                copyArray(base, arr, sz);
                resetCounters();

                double ms = -1.0;

                if (!skip) {
                    auto t0 = high_resolution_clock::now();

                    if (ai == 0) bubbleSortGPA(arr, sz);
                    else if (ai == 1) insertionSortID(arr, sz);
                    else if (ai == 2) selectionSortAge(arr, sz);
                    else if (ai == 3) mergeSortName(arr, 0, sz - 1);
                    else              quickSortGPA(arr, 0, sz - 1);

                    auto t1 = high_resolution_clock::now();
                    ms = duration<double, milli>(t1 - t0).count();
                }

                BenchResult& r = benchResults[benchCount++];
                r.algorithm = algNames[ai];
                r.dataSize = sz;
                r.dataType = dataTypes[di];
                r.timeMs = ms;
                r.comparisons = skip ? -1 : g_comparisons;
                r.swaps = skip ? -1 : g_swaps;

                cout << "    " << algNames[ai] << " [n=" << sz << "] ";
                if (skip) cout << "\033[33mSKIPPED\033[0m\n";
                else      cout << "\033[32m" << ms << " ms\033[0m\n";
            }

            delete[] base;
            delete[] arr;
        }
    }

    cout << "\n\n";
    printSep();
    cout << "\033[1m  BENCHMARK RESULTS\033[0m\n";
    printSep();

    cout << "\033[36m\n  Algorithm        | Size     | Data Type      | Time (ms)    | Comparisons   | Swaps\033[0m\n";
    cout << "  -----------------+----------+----------------+--------------+---------------+-----------\n";

    for (int i = 0; i < benchCount; i++) {
        BenchResult& r = benchResults[i];
        cout << "  ";
        cout.width(17); cout << left << r.algorithm << "| ";
        cout.width(9);  cout << left << r.dataSize << "| ";
        cout.width(15); cout << left << r.dataType << "| ";

        if (r.timeMs < 0) {
            cout.width(13); cout << left << "SKIPPED";
        }
        else {
            cout.width(13); cout << left << r.timeMs;
        }
        cout << "| ";

        if (r.comparisons < 0) {
            cout.width(14); cout << left << "SKIPPED";
        }
        else {
            cout.width(14); cout << left << r.comparisons;
        }
        cout << "| ";

        if (r.swaps < 0) cout << "SKIPPED";
        else             cout << r.swaps;
        cout << "\n";
    }

    printSep();
    cout << "  \033[2mO(n²) algorithms skipped at n=100,000 (impractical runtime).\033[0m\n";
}

