bool idExists(int id) {
    for (int i = 0; i < n; i++) {
        g_comparisons++;
        if (students[i].id == id) return true;
    }
    return false;
}

bool isValidName(const string& name) {
    if (name.empty()) return false;
    for (char c : name)
        if (!isalpha(c) && c != ' ') return false;
    for (char c : name)
        if (c != ' ') return true;
    return false;
}

