void statistics() {
    printHeader("STATISTICAL ANALYSIS");
    if (n == 0) { cout << "  No data.\n"; return; }

    double sum = 0, maxG = students[0].gpa, minG = students[0].gpa;
    for (int i = 0; i < n; i++) {
        sum += students[i].gpa;
        if (students[i].gpa > maxG) maxG = students[i].gpa;
        if (students[i].gpa < minG) minG = students[i].gpa;
    }
    double mean = sum / n;
    double var = 0;
    for (int i = 0; i < n; i++) var += (students[i].gpa - mean) * (students[i].gpa - mean);
    double stdDev = sqrt(var / n);

    Student* temp = new Student[n];
    copyArray(students, temp, n);
    quickSortGPA(temp, 0, n - 1);
    double median = (n % 2 == 0)
        ? (temp[n / 2 - 1].gpa + temp[n / 2].gpa) / 2.0
        : temp[n / 2].gpa;
    delete[] temp;

    cout << "  \033[1mTotal Students\033[0m : " << n << "\n";
    cout << "  \033[1mAverage GPA   \033[0m : " << mean << "\n";
    cout << "  \033[1mMedian GPA    \033[0m : " << median << "\n";
    cout << "  \033[1mHighest GPA   \033[0m : \033[32m" << maxG << "\033[0m\n";
    cout << "  \033[1mLowest GPA    \033[0m : \033[31m" << minG << "\033[0m\n";
    cout << "  \033[1mStd Deviation \033[0m : " << stdDev << "\n";

    int dist[5] = { 0 };
    for (int i = 0; i < n; i++) {
        double g = students[i].gpa;
        if (g < 1.0) dist[0]++;
        else if (g < 2.0) dist[1]++;
        else if (g < 3.0) dist[2]++;
        else if (g < 3.5) dist[3]++;
        else              dist[4]++;
    }
    const char* grades[] = { "F  < 1.0 ", "D  1-1.99", "C  2-2.99", "B  3-3.49", "A  3.5-4 " };
    const char* colours[] = { "\033[31m","\033[33m","\033[34m","\033[32m","\033[32m" };
    cout << "\n  GPA Distribution:\n\n";
    for (int i = 0; i < 5; i++) {
        int bars = (n > 0) ? (dist[i] * 30 / n) : 0;
        cout << "  " << colours[i] << grades[i] << "\033[0m  [";
        for (int b = 0; b < bars; b++) cout << colours[i] << "█\033[0m";
        for (int b = bars; b < 30; b++) cout << "░";
        cout << "] " << dist[i] << "\n";
    }
}

