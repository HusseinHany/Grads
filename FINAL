// LINEAR SEARCH 
int linearSearchName(const string& name) {
    for (int i = 0; i < n; i++) {
        g_comparisons++;
        if (students[i].name == name) return i;
    }
    return -1;
}

int linearSearchPartial(const string& query) {
    string q = query;
    for (char& c : q) c = tolower(c);
    for (int i = 0; i < n; i++) {
        string nm = students[i].name;
        for (char& c : nm) c = tolower(c);
        if (nm.find(q) != string::npos) return i;
    }
    return -1;
}

// BINARY SEARCH 
int binarySearchID(Student arr[], int size, int id) {
    int left = 0, right = size - 1;
    while (left <= right) {
        int mid = left + (right - left) / 2;
        g_comparisons++;
        if (arr[mid].id == id)      return mid;
        else if (arr[mid].id < id)  left = mid + 1;
        else                        right = mid - 1;
    }
    return -1;
}

